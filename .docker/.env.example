# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Kratos DSN
KRATOS_DSN=postgres://<user>:<password>@postgres:5432/kratos_db?sslmode=disable&max_conns=20&max_idle_conns=4

# Kratos Secrets (exactly 32 characters each)
SECRETS_COOKIE=<32-char-hex-string>
SECRETS_CIPHER=<32-char-hex-string>

# Courier SMTP
COURIER_SMTP_CONNECTION_URI=smtps://<user>:<password>@<host>:<port>/?skip_ssl_verify=true

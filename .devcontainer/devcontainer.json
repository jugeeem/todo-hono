{
  "name": "service-template",
  "dockerComposeFile": "../.docker/docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/service-template",
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/shyim/devcontainers-features/bun:latest": {},
    "ghcr.io/robbert229/devcontainer-features/postgresql-client:latest": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-docker",
        "Prisma.prisma",
        "oven.bun-vscode",
        "ms-ossdata.vscode-pgsql"
      ],
      "settings": {
        "sqltools.connections": [
          {
            "name": "todo_db (dev)",
            "driver": "PostgreSQL",
            "host": "postgres",
            "port": 5432,
            "database": "todo_db",
            "username": "postgres",
            "password": "postgres"
          },
          {
            "name": "todo_db_test",
            "driver": "PostgreSQL",
            "host": "postgres",
            "port": 5432,
            "database": "todo_db_test",
            "username": "postgres",
            "password": "postgres"
          }
        ]
      }
    }
  },
  "postCreateCommand": "printf '#!/bin/sh\\n\"$BROWSER\" \"$@\"\\n' > /usr/local/bin/xdg-open && chmod +x /usr/local/bin/xdg-open",
  "remoteUser": "root"
}
